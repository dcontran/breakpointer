{
    "name": "breakpointer",
    "displayName": "breakpointer",
    "description": "",
    "version": "0.0.1",
    "publisher": "dcontreras",
    "repository": {"type": "git", "url": "https://github.com/dcontreras/breakpointer"},
    "license": "MIT",
    "engines": {
        "vscode": "^1.125.0"
    },
    "categories": [
        "Other"
    ],
    "activationEvents": [],
    "main": "./dist/extension.js",
    "contributes": {
        "commands": [
            {
                "command": "breakpointer.copyCurrentLine",
                "title": "Copy Current Line to Clipboard"
            }
        ],
        "menus": {
            "editor/context": [
                {
                    "command": "breakpointer.copyCurrentLine",
                    "group": "navigation"
                }
            ]
        }
    },
    "scripts": {
        "vscode:prepublish": "yarn run package",
        "compile": "webpack",
        "watch": "webpack --watch",
        "package": "webpack --mode production --devtool hidden-source-map",
        "compile-tests": "tsc -p . --outDir out",
        "watch-tests": "tsc -p . -w --outDir out",
        "pretest": "yarn run compile-tests && yarn run compile && yarn run lint",
        "lint": "eslint src",
        "test": "vscode-test"
    },
    "devDependencies": {
        "@types/vscode": "^1.125.0",
        "@types/mocha": "^10.0.10",
        "@types/node": "24.x",
        "typescript-eslint": "^8.61.1",
        "eslint": "^10.5.0",
        "typescript": "^6.0.3",
        "ts-loader": "^9.6.2",
        "webpack": "^5.107.2",
        "webpack-cli": "^7.0.3",
        "@vscode/test-cli": "^0.0.15",
        "@vscode/test-electron": "^3.0.0"
    },
    "overrides": {
        "diff": "^8.0.4",
        "serialize-javascript": "^7.0.6"
    }
}
